# ── Database (Postgres via docker-compose) ───────────────────────────────────
# Ports are offset (5433/6380/9002) so this stack can run beside other local projects.
# In production (e.g. Supabase) DATABASE_URL is the pooled (pgBouncer, :6543) URL
# and DIRECT_URL is the direct (:5432) URL used for migrations.
DATABASE_URL="postgresql://fanhub:fanhub_dev_pw@localhost:5433/fanhub?schema=public"
DIRECT_URL="postgresql://fanhub:fanhub_dev_pw@localhost:5433/fanhub?schema=public"

# ── Redis (cache / rate-limit / chart) — OPTIONAL ────────────────────────────
# Omit on serverless without Redis: rate-limit fails open, ticker/chart use the DB.
REDIS_URL="redis://localhost:6380"

# ── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-32-byte-random-secret"
# Base URL of the app (used for callbacks / magic links)
AUTH_URL="http://localhost:3000"

# ── Email (magic-link sign-in). In dev the Mock transport logs links to stdout.
EMAIL_FROM="FanHub <no-reply@fanhub.local>"
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=""
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""

# ── Storage (MinIO / S3-compatible) ──────────────────────────────────────────
S3_ENDPOINT="http://localhost:9002"
S3_REGION="us-east-1"
S3_BUCKET="fanhub-content"
S3_ACCESS_KEY_ID="fanhub"
S3_SECRET_ACCESS_KEY="fanhub_dev_pw"
S3_FORCE_PATH_STYLE="true"

# ── Payments ─────────────────────────────────────────────────────────────────
# Active provider: "mock" (dev/test default) or "ccbill" (stub).
PAYMENT_PROVIDER="mock"
# HMAC secret used by MockProvider to sign/verify simulated webhooks.
PAYMENT_WEBHOOK_SECRET="dev-mock-webhook-secret"

# CCBill (stub only — never commit real keys). Left blank in dev.
CCBILL_ACCOUNT_NUMBER=""
CCBILL_SUBACCOUNT=""
CCBILL_SALT=""
